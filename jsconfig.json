// This file is used to configure the JavaScript language service and the TypeScript compiler.
// The presence of a jsconfig.json file in a directory indicates that the directory is the root of a JavaScript Project.
// The jsconfig.json file specifies the root files and the options for the features provided by the JavaScript language service.
// The presence of a jsconfig.json file in a directory indicates that the directory is the root of a JavaScript Project. The file specifies the root files and the options for the features provided by the JavaScript language service.
{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@pages/*": [
        "./pages/*"
      ],
      "@styles/*": [
        "./styles/*"
      ],
      "@ui/*": [
        "./components/ui/*"
      ],
    },
    "jsx": "preserve",
    "target": "es6",
    "module": "ESNext",
    "moduleResolution": "node",
  },
  "exclude": [
    "node_modules"
  ]
}